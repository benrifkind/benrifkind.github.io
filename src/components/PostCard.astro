---
interface Props {
  title: string;
  date: Date;
  slug: string;
  tags?: string[];
}

const { title, date, slug, tags } = Astro.props;
const formattedDate = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<article class="group">
  <a href={`/posts/${slug}`} class="block p-5 -mx-5 rounded-xl hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
    <time class="text-sm text-gray-500 dark:text-gray-400">{formattedDate}</time>
    <h3 class="mt-1 text-lg font-semibold text-gray-900 dark:text-white group-hover:text-primary dark:group-hover:text-primary-dark transition-colors">
      {title}
    </h3>
    {tags && tags.length > 0 && (
      <div class="mt-2 flex flex-wrap gap-2">
        {tags.map(tag => (
          <span class="text-xs px-2 py-0.5 bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 rounded-full">
            {tag}
          </span>
        ))}
      </div>
    )}
  </a>
</article>
