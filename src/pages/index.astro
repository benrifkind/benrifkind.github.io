---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);
---
<BaseLayout title="Home">
  <section class="flex flex-col md:flex-row gap-8 items-start mb-16">
    <img
      src="/images/BenR2.jpg"
      alt="Ben Rifkind"
      class="w-32 h-32 rounded-full object-cover ring-4 ring-gray-100 dark:ring-gray-800"
    />
    <div>
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Ben Rifkind</h1>
      <p class="mt-3 text-lg text-gray-600 dark:text-gray-300 max-w-xl">
        I recently completed my Ph.D in probability at the University of Toronto. Now I am messing around with R, Python, and statistical analysis.
      </p>
      <div class="mt-4 flex gap-3">
        <a href="https://github.com/benrifkind" class="text-gray-500 hover:text-gray-900 dark:hover:text-white transition-colors" aria-label="GitHub">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <section>
    <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">Recent Posts</h2>
    <div class="space-y-2">
      {posts.map(post => (
        <PostCard
          title={post.data.title}
          date={post.data.date}
          slug={post.id}
          tags={post.data.tags}
        />
      ))}
    </div>
    <a href="/posts" class="inline-block mt-6 text-sm font-medium text-primary dark:text-primary-dark hover:underline">
      View all posts &rarr;
    </a>
  </section>
</BaseLayout>
